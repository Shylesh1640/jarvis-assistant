# Local model server
OLLAMA_BASE_URL=http://localhost:11434

# Local model names (match your `ollama list` output)
GENERAL_MODEL=qwen3:8b
STRONG_LOCAL_MODEL=qwen3:14b
CODING_MODEL=qwen3-coder:30b
EMBEDDING_MODEL=qwen3-embedding:latest

# Cloud fallback (optional)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
COMPLEX_MODEL_CHAIN=anthropic/claude-opus-4.1,openai/gpt-5.5,google/gemini-2.5-pro

# App
APP_ENV=development
LOG_LEVEL=INFO
VECTOR_DB_PATH=./data/vector_store
